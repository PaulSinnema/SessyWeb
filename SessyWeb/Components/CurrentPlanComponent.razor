@using SessyController.Services.Statistics
@using SessyWeb.Components
@using Radzen
@using Radzen.Blazor

<RadzenCard>
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
        <RadzenText TextStyle="TextStyle.H6">🗓️ Current Plan</RadzenText>
        @if (Dashboard!.Plan!.IsRestoredFromDb)
        {
            <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="Restored from database" />
        }
        <RadzenButton Text="Clear plan" Icon="delete"
                      ButtonStyle="ButtonStyle.Danger"
                      Size="ButtonSize.Small"
                      Click="@OnClearPlanAsync"
                      title="Removes the current plan from memory and database. A fresh plan will be built on the next cycle." />
    </RadzenStack>
    <RadzenRow Gap="8px">
        <RadzenColumn Size="6" SizeMD="3">
            <StatCardComponent Title="Last generated"
                               Value="@(Dashboard!.Plan!.LastBuildTime.HasValue ? Dashboard.Plan.LastBuildTime.Value.ToString("dd-MM-yyyy HH:mm") : "Restored from DB")"
                               Highlight="@(Dashboard!.Plan.LastBuildTime.HasValue)" />
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="3">
            <StatCardComponent Title="Plan horizon"
                               Value="@(Dashboard!.Plan!.PlanHorizon.HasValue ? Dashboard.Plan.PlanHorizon.Value.ToString("dd-MM-yyyy HH:mm") : "—")" />
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="3">
            <StatCardComponent Title="Expected profit"
                               Value="@($"€ {Dashboard!.Plan!.ExpectedProfitEur:F2}")"
                               Highlight="true" />
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="3">
            <StatCardComponent Title="Next charge"
                               Value="@(Dashboard!.Plan!.NextChargeTime.HasValue ? Dashboard!.Plan.NextChargeTime.Value.ToString("HH:mm") : "—")" />
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="3">
            <StatCardComponent Title="Next discharge"
                               Value="@(Dashboard!.Plan!.NextDischargeTime.HasValue ? Dashboard!.Plan.NextDischargeTime.Value.ToString("HH:mm") : "—")" />
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="3">
            <StatCardComponent Title="Quarters: charge / discharge / NZH"
                               Value="@($"{Dashboard!.Plan!.ChargingQuarters} / {Dashboard.Plan.DischargingQuarters} / {Dashboard.Plan.NzhQuarters}")" />
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="3">
            <StatCardComponent Title="Future quarters"
                               Value="@($"{Dashboard!.Plan!.TotalFutureQuarters} ({Dashboard.Plan.TotalFutureQuarters / 4.0:F1} hrs)")" />
        </RadzenColumn>
    </RadzenRow>
    <RadzenText TextStyle="TextStyle.Caption" Style="margin-top: 0.75rem; opacity: 0.7;">
        Expected profit covers all @Dashboard!.Plan!.TotalFutureQuarters future quarters (@($"{Dashboard.Plan.TotalFutureQuarters / 4.0:F1}") hrs).
        The Arbitrage chart shows daily realized vs planned profit for past days only.
    </RadzenText>

    @if (Dashboard!.Plan!.RecentHistory.Any())
    {
        <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mt-4">Plan history</RadzenText>
        <RadzenDataGrid Data="@Dashboard.Plan.RecentHistory"
                        TItem="SessyData.Services.PlanHistoryEntry"
                        Density="Density.Compact"
                        AllowSorting="false"
                        AllowFiltering="false"
                        AllowPaging="false">
            <Columns>
                <RadzenDataGridColumn TItem="SessyData.Services.PlanHistoryEntry" Title="Generated at">
                    <Template Context="h">@h.SavedAt.ToString("dd-MM-yyyy HH:mm")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn Property="@nameof(SessyData.Services.PlanHistoryEntry.Reason)" Title="Reason" />
                <RadzenDataGridColumn TItem="SessyData.Services.PlanHistoryEntry" Title="Expected profit">
                    <Template Context="h">€ @h.ObjectiveEur.ToString("F2")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SessyData.Services.PlanHistoryEntry" Title="Quarters">
                    <Template Context="h">@h.QuarterCount (@($"{h.QuarterCount / 4.0:F1}") hrs)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SessyData.Services.PlanHistoryEntry" Title="Horizon">
                    <Template Context="h">@h.PlanHorizon.ToString("dd-MM HH:mm")</Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
</RadzenCard>

@code {
    [Parameter, EditorRequired] public DashboardStatistics? Dashboard { get; set; }
    [Parameter, EditorRequired] public EventCallback OnClearPlanAsync { get; set; }
}

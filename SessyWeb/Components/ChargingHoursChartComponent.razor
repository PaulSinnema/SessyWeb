﻿@using SessyWeb.Helpers
@using SessyWeb.Pages
@using System.Globalization

@inherits BaseComponent

<style>
    /* Hide the "now" vertical line from the legend (always the last series). */
    .now-chart .rz-legend-item:last-child {
        display: none;
    }
</style>

<div class="now-chart" style="width: 100%; overflow: auto;">
    <RadzenChart Style=@GraphStyle @ref=@QuarterlyHourChart AllowSeriesHover="false">
        <RadzenLegend Position="@((ScreenInfo?.IsMobile ?? false) ? LegendPosition.Right : LegendPosition.Top)" Visible="true" />
        <RadzenChartTooltipOptions Shared="false" Visible="true" />

        <RadzenColumnSeries Data="@QuarterlyInfos"
                            CategoryProperty="Time"
                            Title="Buying price (€/kWh)"
                            Fill="#324ab2"
                            Stroke="#324ab2"
                            ValueProperty="BuyingPrice">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="true" Appearance="DataLabelAppearance.Plain" />
                @if (IsExpected(QuarterlyInfos))
                {
                    <RadzenSeriesAnnotation Data="@QuarterlyInfos.First(q => q.IsPriceExpected)"
                                            Text="↑ Prices are predicted, plan will be calculated after EPEX prices arrive →"
                                            OffsetX="220"
                                            OffsetY="300"
                                            Fill="orange" />
                }
                @if (ShowAll && NowQuarter != null)
                {
                    <RadzenSeriesAnnotation Data="@NowQuarter"
                                            Text="← now"
                                            OffsetX="50"
                                            OffsetY="-150"
                                            Fill="white" />
                }
            </ChildContent>
        </RadzenColumnSeries>

        <RadzenColumnSeries Data="@QuarterlyInfos"
                            CategoryProperty="Time"
                            Title="Selling price (€/kWh)"
                            Fill="#00aae4"
                            Stroke="#00aae4"
                            LineType="LineType.Dashed"
                            ValueProperty="SellingPrice">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="@ShowSellingPriceLabels" Appearance="DataLabelAppearance.Plain" />
            </ChildContent>
        </RadzenColumnSeries>

        <RadzenColumnSeries Data="@QuarterlyInfos"
                            CategoryProperty="Time"
                            Title="Cost basis (€/kWh)"
                            Fill="#9b59b6"
                            Stroke="#9b59b6"
                            ValueProperty="ProjectedCostBasisEur">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
            </ChildContent>
        </RadzenColumnSeries>

        <RadzenColumnSeries Visible="@WeAreInControl"
                            Data="@QuarterlyInfos"
                            Stroke="green"
                            Fill="orange"
                            Title="Revenue (€/quarter)"
                            CategoryProperty="Time"
                            ValueProperty="Profit">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>

            <ChildContent>
                @{
                    if (QuarterlyInfos != null)
                    {
                        foreach (var item in QuarterlyInfos.Where(qi => qi.Profit != 0.0))
                        {
                            <RadzenSeriesAnnotation Visible="true"
                                                    TItem="QuarterlyInfoView"
                                                    Data="@item"
                                                    OffsetX="12"
                                                    OffsetY="@(item.Profit > 0.00 ? -16 : 16)"
                                                    Text="@(String.Format(CultureInfo.CurrentCulture, "{0:0.00}", item.Profit))"
                                                    Fill="orange" />
                        }
                    }
                }
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenColumnSeries>

        <RadzenAreaSeries Visible="@WeAreInControl"
                          Data="@QuarterlyInfos"
                          Smooth="true"
                          CategoryProperty="Time"
                          Fill="rgba(255, 215, 0, 0.5)"
                          Stroke="#ffd700"
                          Title="Zero net home"
                          ValueProperty="ZeroNetHomeVisual">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenAreaSeries>

        <RadzenAreaSeries Data="@QuarterlyInfos"
                          Smooth="true"
                          CategoryProperty="Time"
                          Fill="rgba(255, 0, 0, 0.45)"
                          Stroke="red"
                          StrokeWidth="1.5"
                          Title="Throttle loss charge (kW)"
                          ValueProperty="UnthrottledChargePowerVisual">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenAreaSeries>

        <RadzenAreaSeries Data="@QuarterlyInfos"
                          Smooth="true"
                          CategoryProperty="Time"
                          Fill="rgba(255, 0, 0, 0.45)"
                          Stroke="red"
                          StrokeWidth="1.5"
                          Title="Throttle loss discharge (kW)"
                          ValueProperty="UnthrottledDischargePowerVisual">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenAreaSeries>

        <RadzenAreaSeries Data="@QuarterlyInfos"
                          Smooth="true"
                          CategoryProperty="Time"
                          Fill="rgba(255, 102, 0, 0.5)"
                          Stroke="#ff6600"
                          Title="Planned charge (kW)"
                          ValueProperty="PlannedChargePowerVisual">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenAreaSeries>

        <RadzenAreaSeries Data="@QuarterlyInfos"
                          Smooth="true"
                          CategoryProperty="Time"
                          Fill="rgba(0, 204, 68, 0.5)"
                          Stroke="#00cc44"
                          Title="Planned discharge (kW)"
                          ValueProperty="PlannedDischargePowerVisual">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenAreaSeries>

        @* Actual battery power, in the same colours as the planned areas. Bound to
           ActualPowerPoints (only quarters with a real reading), so these end at "now" instead
           of tracing the plan a second time across the future. *@
        <RadzenAreaSeries Data="@ActualPowerPoints"
                          Smooth="true"
                          CategoryProperty="Time"
                          Fill="rgba(255, 102, 0, 0.5)"
                          Stroke="#ff6600"
                          Title="Charge power actual (kW)"
                          ValueProperty="ChargePowerVisual">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                @* Marker needed because without "Show all" only the executing quarter has a
                   real reading — a one-point area renders as nothing. *@
                <RadzenMarkers Visible="true" MarkerType="MarkerType.Circle" Size="4" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenAreaSeries>

        <RadzenAreaSeries Data="@ActualPowerPoints"
                          Smooth="true"
                          CategoryProperty="Time"
                          Fill="rgba(0, 204, 68, 0.5)"
                          Stroke="#00cc44"
                          Title="Discharge power actual (kW)"
                          ValueProperty="DischargePowerVisual">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="true" MarkerType="MarkerType.Circle" Size="4" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenAreaSeries>

        <RadzenLineSeries Data="@QuarterlyInfos"
                          Smooth="true"
                          CategoryProperty="Time"
                          Stroke="#324ab2"
                          Title="Smoothed buying price (€/kWh)"
                          LineType="LineType.Solid"
                          ValueProperty="SmoothedBuyingPrice">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenLineSeries>

        <RadzenLineSeries Data="@QuarterlyInfos"
                          Smooth="true"
                          CategoryProperty="Time"
                          Stroke="#00aae4"
                          Title="Smoothed selling price (€/kWh)"
                          LineType="LineType.Solid"
                          ValueProperty="SmoothedSellingPrice">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenLineSeries>

        <RadzenLineSeries Data="@QuarterlyInfos"
                          Smooth="true"
                          CategoryProperty="Time"
                          Stroke="red"
                          Title="Charge remaining (kWh)"
                          ValueProperty="ChargeLeftVisual">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenLineSeries>

        <RadzenLineSeries Data="@QuarterlyInfos"
                          Smooth="true"
                          CategoryProperty="Time"
                          Stroke="gold"
                          Title="Solar power (kWh/quarter)"
                          LineType="LineType.Solid"
                          ValueProperty="SmoothedSolarPowerVisual">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenLineSeries>

        <RadzenLineSeries Visible="@WeAreInControl"
                          Data="@QuarterlyInfos"
                          Smooth="true"
                          CategoryProperty="Time"
                          Stroke="#b06500"
                          Title="Charge needed (kWh)"
                          LineType="LineType.Solid"
                          ValueProperty="ChargeNeededVisual">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenLineSeries>

        <RadzenLineSeries Data="@QuarterlyInfos"
                          Smooth="true"
                          CategoryProperty="Time"
                          Title="Est. consumption (W)"
                          LineType="LineType.Solid"
                          ValueProperty="SmoothedConsumptionVisual">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenLineSeries>

        <RadzenLineSeries Data="@QuarterlyInfos"
                          Smooth="true"
                          CategoryProperty="Time"
                          Title="Delta lowest price (€/kWh)"
                          LineType="LineType.Solid"
                          ValueProperty="DeltaLowestPrice">
            <TooltipTemplate Context="data">
                <ChargingHoursTooltip QuarterlyInfo=@data />
            </TooltipTemplate>
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenLineSeries>

        <RadzenLineSeries Visible="@ShowPlanHistory"
                          Data="@PlanPoints"
                          Smooth="true"
                          CategoryProperty="Time"
                          Stroke="#ff33cc"
                          StrokeWidth="3.5"
                          LineType="LineType.Solid"
                          Title="Plan history (kW)"
                          ValueProperty="PlanPowerVisual">
            <ChildContent>
                <RadzenMarkers Visible="false" />
                <RadzenSeriesDataLabels Visible="false" />
            </ChildContent>
        </RadzenLineSeries>

        @* Vertical "now" line — single full-height bar at the current quarter. *@
        @if (ShowAll && NowQuarter != null)
        {
            <RadzenColumnSeries Data="@(new[] { NowQuarter })"
                                CategoryProperty="Time"
                                ValueProperty="NowLineHeight"
                                Fill="rgba(255,255,255,0.3)"
                                Stroke="white"
                                StrokeWidth="1">
                <ChildContent>
                    <RadzenSeriesDataLabels Visible="false" />
                </ChildContent>
            </RadzenColumnSeries>
        }

        <RadzenCategoryAxis Padding="40" Formatter="@Formatters.FormatAsDayHour" TickDistance="152">
            <RadzenGridLines Visible="true" />
            <RadzenAxisTitle Text="Time" />
        </RadzenCategoryAxis>

        <RadzenValueAxis Formatter="@Formatters.FormatAsPrice" Min="@ChartMin" Max="@ChartMax" Step="0.10">
            <RadzenGridLines Visible="true" />
            <RadzenAxisTitle Text="Price" />
        </RadzenValueAxis>

        <RadzenBarOptions Radius="5" />
    </RadzenChart>
</div>
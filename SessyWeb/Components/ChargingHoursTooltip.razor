@inherits BaseComponent

@{
    var q = QuarterlyInfo;
    string fmt(double? v, string f = "0.00") => (v ?? 0).ToString(f, System.Globalization.CultureInfo.GetCultureInfo("nl-NL"));

    // State accent color.
    string stateColor = q?.DisplayState switch
    {
        "Charging" => "#ffaa33",
        "Discharging" => "#66ff99",
        _ => "var(--rz-text-color, #9aa)"
    };

    bool hasPlan = !string.IsNullOrEmpty(q?.PlannedDisplayState);
    bool hasDeviation = !string.IsNullOrEmpty(q?.PlanDeviationReason);
    bool charging = (q?.ChargePowerW ?? 0) > 10;
    bool discharging = (q?.DischargePowerW ?? 0) > 10;
}

<div class="sw-tt">
    <div class="sw-tt-head">
        <span class="sw-tt-title">@q?.Time.ToString("dd MMM HH:mm", System.Globalization.CultureInfo.GetCultureInfo("nl-NL"))</span>
        <span class="sw-tt-state" style="color:@stateColor;">@q?.DisplayState</span>
    </div>

    <div class="sw-tt-grid">
        <span class="sw-tt-k">Buy / Sell</span>
        <span class="sw-tt-v">@fmt(q?.BuyingPrice, "0.0000") / @fmt(q?.SellingPrice, "0.0000")</span>

        <span class="sw-tt-k">Market</span>
        <span class="sw-tt-v">@fmt(q?.MarketPrice, "0.0000")</span>

        <span class="sw-tt-k">Revenue</span>
        <span class="sw-tt-v">@fmt(q?.Profit)</span>

        <span class="sw-tt-k">Solar / radiation</span>
        <span class="sw-tt-v">@fmt(q?.SolarPowerPerQuarterHour) / @fmt(q?.SolarGlobalRadiation)</span>

        <span class="sw-tt-k">Consumption</span>
        <span class="sw-tt-v">@fmt(q?.EstimatedConsumptionPerQuarterHour)</span>

        <span class="sw-tt-k">Charge left</span>
        <span class="sw-tt-v">@fmt(q?.ChargeLeft, "0") Wh · @fmt(q?.ChargeLeftPercentage, "0.0")%</span>

        <span class="sw-tt-k">Charge needed</span>
        <span class="sw-tt-v">@fmt(q?.ChargeNeeded, "0") Wh · @fmt(q?.ChargeNeededPercentage, "0.0")%</span>

        <span class="sw-tt-k">Cost basis</span>
        <span class="sw-tt-v">@fmt(q?.ProjectedCostBasisEur, "0.0000")</span>

        <span class="sw-tt-k">Discharge profitable?</span>
        <span class="sw-tt-v">
            @{
                double costBasis = q?.ProjectedCostBasisEur ?? 0.0;
                double sell = q?.SellingPrice ?? 0.0;
                bool profitable = sell > costBasis + CycleCost;
            }
            @if (profitable)
            {
                <span style="color:#66ff99;">yes (€@fmt(sell - costBasis - CycleCost, "0.0000") margin)</span>
            }
            else
            {
                <span style="opacity:.7;">no</span>
            }
        </span>
    </div>

    <div class="sw-tt-sep"></div>

    <div class="sw-tt-grid">
        <span class="sw-tt-k">Actual power</span>
        <span class="sw-tt-v">
            @if (charging)
            {
                <span style="color:#ffaa33;">charge @fmt(q?.ChargePowerW, "0") W</span>
            }
            else if (discharging)
            {
                <span style="color:#66ff99;">discharge @fmt(q?.DischargePowerW, "0") W</span>
            }
            else
            {
                <span>idle</span>
            }
        </span>

        @if (hasPlan)
        {
            <span class="sw-tt-k">Planned</span>
            <span class="sw-tt-v">
                @q?.PlannedDisplayState
                @if ((q?.PlannedChargePowerW ?? 0) > 10)
                {
                    <text> · </text><span style="color:#ffaa33;">@fmt(q?.PlannedChargePowerW, "0") W</span>
                }
                else if ((q?.PlannedDischargePowerW ?? 0) > 10)
                {
                    <text> · </text><span style="color:#66ff99;">@fmt(q?.PlannedDischargePowerW, "0") W</span>
                }
            </span>

            <span class="sw-tt-k">Planned SOC</span>
            <span class="sw-tt-v">@fmt(q?.PlannedChargeLeftWh, "0") Wh</span>
        }
    </div>

    @if (hasDeviation)
    {
        <div class="sw-tt-note">@q?.PlanDeviationReason</div>
    }
</div>

<style>
    .sw-tt {
        font-size: 12px;
        line-height: 1.35;
        min-width: 300px;
        max-width: 360px;
        padding: 2px 4px;
    }

    .sw-tt-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 4px;
        gap: 8px;
    }

    .sw-tt-title {
        font-weight: 600;
    }

    .sw-tt-state {
        font-weight: 600;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: .03em;
    }

    .sw-tt-grid {
        display: grid;
        grid-template-columns: auto 1fr;
        column-gap: 10px;
        row-gap: 1px;
    }

    .sw-tt-k {
        opacity: .7;
        white-space: nowrap;
    }

    .sw-tt-v {
        text-align: right;
        font-variant-numeric: tabular-nums;
    }

    .sw-tt-sep {
        height: 1px;
        background: currentColor;
        opacity: .15;
        margin: 5px 0;
    }

    .sw-tt-note {
        margin-top: 5px;
        font-style: italic;
        opacity: .8;
        font-size: 11px;
        border-left: 2px solid currentColor;
        padding-left: 6px;
    }
</style>

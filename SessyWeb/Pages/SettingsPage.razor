@page "/settings"
@inherits PageBase
@using SessyData.Model
@using Radzen
@using Radzen.Blazor

<RadzenLayout Style="height: 80vh;">
    <RadzenHeader Style="height: 100%; margin: 0px; padding: 0px;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Style="height:100%; margin: 0px; padding: 0px;">
            <RadzenLabel Text="Settings" class="h4 m-2" />
        </RadzenStack>
    </RadzenHeader>

    <RadzenBody Style="margin: 8px; padding: 0px; overflow-y: auto;">
        <RadzenTabs RenderMode="TabRenderMode.Client">

            @* ── Investment Groups ─────────────────────────────────────────── *@
            <Tabs>
                @* ── Management Settings ───────────────────────────────────── *@
                <RadzenTabsItem Text="Management Settings" Icon="settings">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="1rem" Style="padding: 1rem; max-width: 900px;">

                        @if (_settings == null)
                        {
                            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                        }
                        else
                        {
                            @* ── Location ────────────────────────────────────── *@
                            <RadzenFieldset Text="Location">
                                <RadzenRow Gap="1rem">
                                    <RadzenColumn Size="12" SizeMD="4">
                                        <RadzenLabel Text="Latitude" />
                                        <RadzenNumeric @bind-Value="_settings.Latitude" Format="F6" Style="width:100%" />
                                    </RadzenColumn>
                                    <RadzenColumn Size="12" SizeMD="4">
                                        <RadzenLabel Text="Longitude" />
                                        <RadzenNumeric @bind-Value="_settings.Longitude" Format="F6" Style="width:100%" />
                                    </RadzenColumn>
                                    <RadzenColumn Size="12" SizeMD="4">
                                        <RadzenLabel Text="Timezone" />
                                        <RadzenTextBox @bind-Value="_settings.TimeZone" Style="width:100%" />
                                    </RadzenColumn>
                                </RadzenRow>
                            </RadzenFieldset>

                            @* ── Solar ───────────────────────────────────────── *@
                            <RadzenFieldset Text="Solar">
                                <RadzenRow Gap="1rem">
                                    <RadzenColumn Size="12" SizeMD="4">
                                        <RadzenLabel Text="Solar correction factor" />
                                        <RadzenNumeric @bind-Value="_settings.SolarCorrection" Format="F2" Style="width:100%" />
                                    </RadzenColumn>
                                    <RadzenColumn Size="12" SizeMD="4">
                                        <RadzenLabel Text="Annual production (kWh)" />
                                        <RadzenNumeric @bind-Value="_settings.SolarAnnualProductionKWh" Format="F0" Style="width:100%" />
                                    </RadzenColumn>
                                    <RadzenColumn Size="12" SizeMD="4" Style="display:flex; align-items:flex-end; padding-bottom:4px;">
                                        <RadzenCheckBox @bind-Value="_settings.SolarSystemShutsDownDuringNegativePrices" />
                                        <RadzenLabel Text="Shut down at negative prices" Style="margin-left:8px" />
                                    </RadzenColumn>
                                </RadzenRow>
                            </RadzenFieldset>

                            @* ── Battery control ──────────────────────────────── *@
                            <RadzenFieldset Text="Battery control">
                                <RadzenRow Gap="1rem">
                                    <RadzenColumn Size="12" SizeMD="4">
                                        <RadzenLabel Text="Cycle cost (€)" />
                                        <RadzenNumeric @bind-Value="_settings.CycleCost" Format="F4" Style="width:100%" />
                                    </RadzenColumn>
                                    <RadzenColumn Size="12" SizeMD="4">
                                        <RadzenLabel Text="Zero Net Home min. profit (€/kWh)" />
                                        <RadzenNumeric @bind-Value="_settings.NetZeroHomeMinProfit" Format="F4" Style="width:100%" />
                                    </RadzenColumn>
                                    <RadzenColumn Size="12" SizeMD="4">
                                        <RadzenLabel Text="Night reserve cap (%)" />
                                        <RadzenNumeric @bind-Value="_settings.NightReserveCapPct" Format="F0" Min="0" Max="100" Style="width:100%" />
                                        <RadzenText TextStyle="TextStyle.Caption">0 = default (33%)</RadzenText>
                                    </RadzenColumn>
                                    <RadzenColumn Size="12" SizeMD="4" Style="display:flex; flex-direction:column; gap:8px; justify-content:flex-end;">
                                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
                                            <RadzenCheckBox @bind-Value="_settings.ChargedInControl" />
                                            <RadzenLabel Text="Charged in control" />
                                        </RadzenStack>
                                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
                                            <RadzenCheckBox @bind-Value="_settings.ManualOverride" />
                                            <RadzenLabel Text="Manual override" />
                                        </RadzenStack>
                                    </RadzenColumn>
                                </RadzenRow>
                                @if (_settings.ManualOverride)
                                {
                                    <RadzenRow Gap="1rem" Style="margin-top:1rem;">
                                        <RadzenColumn Size="12" SizeMD="4">
                                            <RadzenLabel Text="Manual charging hours" />
                                            <RadzenDropDown @bind-Value="_chargingHours"
                                                            Data="@_allHours"
                                                            Multiple="true" AllowClear="true"
                                                            Placeholder="— select hours —" Style="width:100%"
                                                            Change="@(() => OnChargingHoursChanged())" />
                                        </RadzenColumn>
                                        <RadzenColumn Size="12" SizeMD="4">
                                            <RadzenLabel Text="Manual discharging hours" />
                                            <RadzenDropDown @bind-Value="_dischargingHours"
                                                            Data="@_allHours"
                                                            Multiple="true" AllowClear="true"
                                                            Placeholder="— select hours —" Style="width:100%"
                                                            Change="@(() => OnDischargingHoursChanged())" />
                                        </RadzenColumn>
                                        <RadzenColumn Size="12" SizeMD="4">
                                            <RadzenLabel Text="Manual Zero Net Home hours" />
                                            <RadzenDropDown @bind-Value="_nzhHours"
                                                            Data="@_allHours"
                                                            Multiple="true" AllowClear="true"
                                                            Placeholder="— select hours —" Style="width:100%"
                                                            Change="@(() => OnNzhHoursChanged())" />
                                        </RadzenColumn>
                                    </RadzenRow>
                                }
                            </RadzenFieldset>

                            @* ── Energy needs per month ───────────────────────── *@
                            <RadzenFieldset Text="Estimated home energy needs per month (kWh)">
                                <RadzenRow Gap="0.5rem">
                                    @for (int m = 0; m < 12; m++)
                                    {
                                        int month = m;
                                        <RadzenColumn Size="6" SizeMD="2">
                                            <RadzenLabel Text="@_monthNames[month]" />
                                            <RadzenNumeric Value="@_energyNeeds[month]"
                                                           ValueChanged="@((double v) => _energyNeeds[month] = v)"
                                                           Format="F0" Style="width:100%" />
                                        </RadzenColumn>
                                    }
                                </RadzenRow>
                            </RadzenFieldset>

                            @* ── Statistics ───────────────────────────────────── *@
                            <RadzenFieldset Text="Statistics">
                                <RadzenRow Gap="1rem">
                                    <RadzenColumn Size="12" SizeMD="6">
                                        <RadzenLabel Text="Statistics from date (optional)" />
                                        <RadzenDatePicker @bind-Value="_settings.StatisticsFromDate"
                                                          DateFormat="dd-MM-yyyy"
                                                          AllowClear="true"
                                                          Placeholder="— all history —"
                                                          Style="width:100%" />
                                    </RadzenColumn>
                                </RadzenRow>
                            </RadzenFieldset>

                            <RadzenRow>
                                <RadzenColumn>
                                    <RadzenButton Text="Save" Icon="save"
                                                  ButtonStyle="ButtonStyle.Success"
                                                  Click="@SaveSettingsAsync"
                                                  IsBusy="@_settingsSaving" />
                                    @if (_settingsSaved)
                                    {
                                        <RadzenText TextStyle="TextStyle.Caption" Style="margin-left:1rem; color:var(--rz-success);">
                                            ✓ Saved
                                        </RadzenText>
                                    }
                                </RadzenColumn>
                            </RadzenRow>
                        }

                    </RadzenStack>
                </RadzenTabsItem>

                <RadzenTabsItem Text="Investment Groups" Icon="category">
                    <RadzenDataGrid @ref="groupsGrid"
                                    Data="@GroupList"
                                    TItem="InvestmentGroup"
                                    Count="@groupCount"
                                    LoadData="@LoadGroupData"
                                    IsLoading="@isGroupLoading"
                                    RowUpdate="@OnUpdateGroup"
                                    RowCreate="@OnCreateGroup"
                                    Responsive="true"
                                    AllowSorting="true"
                                    AllowFiltering="true"
                                    AllowPaging="true"
                                    PageSize="20"
                                    Density="Density.Compact"
                                    PagerHorizontalAlign="HorizontalAlign.Left">
                        <HeaderTemplate>
                            <RadzenButton ButtonStyle="ButtonStyle.Success"
                                          Icon="add_circle"
                                          Text="Add group"
                                          Click="@InsertGroup" />
                        </HeaderTemplate>
                        <Columns>
                            <RadzenDataGridColumn Property="@nameof(InvestmentGroup.Name)" Title="Name">
                                <EditTemplate Context="grp">
                                    <RadzenTextBox @bind-Value="grp.Name" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(InvestmentGroup.Category)" Title="Category">
                                <EditTemplate Context="grp">
                                    <RadzenDropDown @bind-Value="grp.Category"
                                                    Data="@Categories"
                                                    Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(InvestmentGroup.Description)" Title="Description">
                                <EditTemplate Context="grp">
                                    <RadzenTextBox @bind-Value="grp.Description" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Context="grp" Filterable="false" Sortable="false"
                                                  TextAlign="TextAlign.Right" Frozen="true"
                                                  FrozenPosition="FrozenColumnPosition.Right">
                                <Template Context="grp">
                                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" class="rz-my-1"
                                                  Click="@(args => EditGroup(grp))" @onclick:stopPropagation="true" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => DeleteGroup(grp))" @onclick:stopPropagation="true" />
                                </Template>
                                <EditTemplate Context="grp">
                                    <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Click="@((args) => SaveGroup(grp))" aria-label="Save" />
                                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" class="rz-my-1 rz-ms-1"
                                                  Click="@((args) => CancelGroupEdit(grp))" aria-label="Cancel" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => DeleteGroup(grp))" aria-label="Delete" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>

                @* ── Investments ───────────────────────────────────────────── *@
                <RadzenTabsItem Text="Investments" Icon="payments">
                    <RadzenDataGrid @ref="investmentsGrid"
                                    Data="@InvestmentList"
                                    TItem="Investment"
                                    Count="@investmentCount"
                                    LoadData="@LoadInvestmentData"
                                    IsLoading="@isInvestmentLoading"
                                    RowUpdate="@OnUpdateInvestment"
                                    RowCreate="@OnCreateInvestment"
                                    Responsive="true"
                                    AllowSorting="true"
                                    AllowFiltering="true"
                                    AllowPaging="true"
                                    PageSize="20"
                                    Density="Density.Compact"
                                    PagerHorizontalAlign="HorizontalAlign.Left">
                        <HeaderTemplate>
                            <RadzenButton ButtonStyle="ButtonStyle.Success" Icon="add_circle"
                                          Text="Add investment" Click="@InsertInvestment" />
                            <RadzenText TextStyle="TextStyle.Body1" class="rz-ms-4">
                                Total: <strong>€ @InvestmentList?.Sum(i => i.AmountEur).ToString("F2")</strong> |
                                Subsidies: <strong>€ @InvestmentList?.Sum(i => i.SubsidyEur).ToString("F2")</strong> |
                                Net: <strong>€ @InvestmentList?.Sum(i => i.NetAmountEur).ToString("F2")</strong>
                            </RadzenText>
                        </HeaderTemplate>
                        <Columns>
                            <RadzenDataGridColumn Property="@nameof(Investment.InvestmentGroupId)" Title="Group">
                                <Template Context="inv">
                                    @(Groups.FirstOrDefault(g => g.Id == inv.InvestmentGroupId)?.Name ?? "—")
                                </Template>
                                <EditTemplate Context="inv">
                                    <RadzenDropDown @bind-Value="inv.InvestmentGroupId"
                                                    Data="@Groups"
                                                    TextProperty="Name"
                                                    ValueProperty="Id"
                                                    AllowClear="true"
                                                    Placeholder="— no group —"
                                                    Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.Description)" Title="Description">
                                <EditTemplate Context="inv">
                                    <RadzenTextBox @bind-Value="inv.Description" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.PurchaseDate)" Title="Purchase date"
                                                  SortOrder="SortOrder.Ascending" FormatString="{0:dd-MM-yyyy}">
                                <EditTemplate Context="inv">
                                    <RadzenDatePicker @bind-Value="inv.PurchaseDate" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.AmountEur)" Title="Amount (€)" FormatString="{0:F2}">
                                <EditTemplate Context="inv">
                                    <RadzenNumeric @bind-Value="inv.AmountEur" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.SubsidyEur)" Title="Subsidy (€)" FormatString="{0:F2}">
                                <EditTemplate Context="inv">
                                    <RadzenNumeric @bind-Value="inv.SubsidyEur" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.NetAmountEur)" Title="Net (€)" FormatString="{0:F2}">
                                <Template Context="inv">@inv.NetAmountEur.ToString("F2")</Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.ExpectedLifetimeYears)" Title="Lifetime (yr)">
                                <EditTemplate Context="inv">
                                    <RadzenNumeric @bind-Value="inv.ExpectedLifetimeYears" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.EstimatedAnnualSavingsEur)" Title="Est. savings (€/yr)" FormatString="{0:F2}">
                                <EditTemplate Context="inv">
                                    <RadzenNumeric @bind-Value="inv.EstimatedAnnualSavingsEur" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.SavingsDescription)" Title="Savings description">
                                <EditTemplate Context="inv">
                                    <RadzenTextBox @bind-Value="inv.SavingsDescription" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.Notes)" Title="Notes">
                                <EditTemplate Context="inv">
                                    <RadzenTextBox @bind-Value="inv.Notes" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Context="inv" Filterable="false" Sortable="false"
                                                  TextAlign="TextAlign.Right" Frozen="true"
                                                  FrozenPosition="FrozenColumnPosition.Right">
                                <Template Context="inv">
                                    <RadzenButton Icon="add_circle" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter"
                                                  Click="@(() => InsertInvestmentAfterRow(inv))"
                                                  title="Add new row after this row" />
                                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => EditInvestment(inv))" @onclick:stopPropagation="true" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => DeleteInvestment(inv))" @onclick:stopPropagation="true" />
                                </Template>
                                <EditTemplate Context="inv">
                                    <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Click="@((args) => SaveInvestment(inv))" aria-label="Save" />
                                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" class="rz-my-1 rz-ms-1"
                                                  Click="@((args) => CancelInvestmentEdit(inv))" aria-label="Cancel" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => DeleteInvestment(inv))" aria-label="Delete" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>

                @* ── Taxes ─────────────────────────────────────────────────── *@
                <RadzenTabsItem Text="Taxes" Icon="receipt_long">
                    <RadzenDataGrid @ref="taxesGrid"
                                    Data="@TaxesList"
                                    TItem="Taxes"
                                    Count="@taxCount"
                                    LoadData="@LoadTaxData"
                                    IsLoading="@isTaxLoading"
                                    RowUpdate="@OnUpdateTax"
                                    RowCreate="@OnCreateTax"
                                    Responsive="true"
                                    AllowSorting="true"
                                    AllowFiltering="true"
                                    AllowPaging="true"
                                    PageSize="20"
                                    Density="Density.Compact"
                                    PagerHorizontalAlign="HorizontalAlign.Left">
                        <HeaderTemplate>
                            <RadzenButton ButtonStyle="ButtonStyle.Success" Icon="add_circle"
                                          Text="Add taxes" Click="@InsertTax" />
                        </HeaderTemplate>
                        <Columns>
                            <RadzenDataGridColumn Property="@nameof(Taxes.Time)" Title="Time" SortOrder="SortOrder.Ascending">
                                <EditTemplate Context="t">
                                    <RadzenDatePicker @bind-Value="t.Time" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.EnergyTax)" Title="Energy tax">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.EnergyTax" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.ValueAddedTax)" Title="Value added tax">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.ValueAddedTax" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.TaxReduction)" Title="Tax reduction">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.TaxReduction" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.PurchaseCompensation)" Title="Purchase compensation">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.PurchaseCompensation" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.ReturnDeliveryCompensation)" Title="Return delivery compensation">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.ReturnDeliveryCompensation" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.NetManagementCost)" Title="Net management cost">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.NetManagementCost" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.FixedTransportFee)" Title="Fixed transport fee">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.FixedTransportFee" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.CapacityTransportFee)" Title="Capacity transport fee">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.CapacityTransportFee" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.Netting)" Title="Netting">
                                <EditTemplate Context="t">
                                    <RadzenCheckBox @bind-Value="t.Netting" Style="width:10%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.GasEnergyTaxEurPerM3)" Title="Gas energy tax (€/m³)">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.GasEnergyTaxEurPerM3" Style="width:100%" Format="F4" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.GasSupplierMarkupEurPerM3)" Title="Gas supplier markup (€/m³)">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.GasSupplierMarkupEurPerM3" Style="width:100%" Format="F4" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.GasValueAddedTaxPct)" Title="Gas VAT (%)">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.GasValueAddedTaxPct" Style="width:100%" Format="F1" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Context="t" Filterable="false" Sortable="false"
                                                  TextAlign="TextAlign.Right" Frozen="true"
                                                  FrozenPosition="FrozenColumnPosition.Right">
                                <Template Context="t">
                                    <RadzenButton Icon="add_circle" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter"
                                                  Click="@(() => InsertTaxAfterRow(t))"
                                                  title="Add new row after this row" />
                                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => EditTax(t))" @onclick:stopPropagation="true" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => DeleteTax(t))" @onclick:stopPropagation="true" />
                                </Template>
                                <EditTemplate Context="t">
                                    <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Click="@((args) => SaveTax(t))" aria-label="Save" />
                                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" class="rz-my-1 rz-ms-1"
                                                  Click="@((args) => CancelTaxEdit(t))" aria-label="Cancel" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => DeleteTax(t))" aria-label="Delete" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>

                @* ── Who's in control ──────────────────────────────────────── *@
                <RadzenTabsItem Text="Who's in control" Icon="tune">
                    <RadzenDataGrid @ref="controlGrid"
                                    Data="@ControlList"
                                    Context="data"
                                    Count="@controlCount"
                                    LoadData="@LoadControlData"
                                    Responsive="true"
                                    AllowSorting="true"
                                    AllowFiltering="true"
                                    AllowPaging="true"
                                    PageSize="20"
                                    Density="Density.Compact"
                                    PagerHorizontalAlign="HorizontalAlign.Center">
                        <Columns>
                            <RadzenDataGridColumn Property="@nameof(SessyWebControl.Time)" Title="Time" SortOrder="SortOrder.Ascending" />
                            <RadzenDataGridColumn Property="@nameof(SessyWebControl.Status)" Title="Status" />
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>

                @* ── Tips & Checks ──────────────────────────────────────────── *@
                <RadzenTabsItem Text="Tips & Checks" Icon="tips_and_updates">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="0.75rem" Style="padding: 1rem; max-width: 900px;">
                        @if (_checks == null)
                        {
                            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
                        }
                        else if (!_checks.Any())
                        {
                            <RadzenText TextStyle="TextStyle.Body1">✅ All checks passed — no issues found.</RadzenText>
                        }
                        else
                        {
                            @foreach (var check in _checks)
                            {
                                <RadzenCard Style="@($"border-left: 4px solid {CheckColor(check.Severity)}; padding: 1rem;")">
                                    <RadzenText TextStyle="TextStyle.Subtitle1">
                                        @check.SeverityIcon @check.Title
                                    </RadzenText>
                                    <RadzenText TextStyle="TextStyle.Body2" Style="margin-top: 0.25rem; opacity: 0.85;">
                                        @check.Description
                                    </RadzenText>
                                    @if (check.ActionUrl != null)
                                    {
                                        <a href="@check.ActionUrl" target="_blank" style="font-size: 0.85rem; margin-top: 0.5rem; display: inline-block;">
                                            @(check.ActionLabel ?? check.ActionUrl)
                                        </a>
                                    }
                                </RadzenCard>
                            }
                        }
                    </RadzenStack>
                </RadzenTabsItem>

                @* ── SQL Console ────────────────────────────────────────────── *@
                <RadzenTabsItem Text="SQL Console" Icon="terminal">
                    <div style="display:flex; flex-direction:column; padding:1rem; gap:0.5rem;">
                        <RadzenText TextStyle="TextStyle.Caption" Style="opacity:0.7; margin:0;">
                            Direct SQL access. Only SELECT, UPDATE or DELETE — no DROP or ALTER.
                        </RadzenText>
                        <div style="display:flex; gap:0.5rem; align-items:flex-start;">
                            <RadzenTextArea @bind-Value="_sqlStatement"
                                            Rows="4"
                                            Style="flex:1; font-family:monospace; resize:vertical;"
                                            Placeholder="SELECT * FROM QuarterlyMeasurements WHERE SolarProductionKwh > 100;" />
                            <div style="display:flex; flex-direction:column; gap:0.5rem;">
                                <RadzenButton Text="Execute" Icon="play_arrow"
                                              ButtonStyle="ButtonStyle.Primary"
                                              Click="@ExecuteSqlAsync"
                                              IsBusy="@_sqlBusy" />
                                <RadzenButton Text="Clear" Icon="clear"
                                              ButtonStyle="ButtonStyle.Light"
                                              Click="@(() => { _sqlStatement = string.Empty; _sqlResult = null; _sqlError = null; })" />
                                <RadzenButton Text="CSV" Icon="download"
                                              ButtonStyle="ButtonStyle.Secondary"
                                              Disabled="@(_sqlResult == null || _sqlResult.Count == 0)"
                                              Click="@ExportCsvAsync" />
                                <RadzenButton Text="Excel" Icon="table_view"
                                              ButtonStyle="ButtonStyle.Secondary"
                                              Disabled="@(_sqlResult == null || _sqlResult.Count == 0)"
                                              Click="@ExportXlsxAsync" />
                            </div>
                        </div>
                        @if (_sqlError != null)
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">@_sqlError</RadzenAlert>
                        }
                        @if (_sqlResult != null)
                        {
                            <RadzenText TextStyle="TextStyle.Caption">@_sqlRowsAffected</RadzenText>
                            @if (_sqlResult.Count > 0)
                            {
                                <div style="overflow-x:auto;">
                                    <RadzenDataGrid Data="@_sqlResult" TItem="Dictionary<string, object>"
                                                    AllowSorting="false" AllowPaging="true"
                                                    PageSize="15"
                                                    PagerHorizontalAlign="HorizontalAlign.Left"
                                                    Style="width:100%;">
                                        <Columns>
                                            @foreach (var col in _sqlColumns)
                                            {
                                                var c = col;
                                                <RadzenDataGridColumn TItem="Dictionary<string, object>" Title="@c">
                                                    <Template Context="row">
                                                        @(row.TryGetValue(c, out var v) ? v?.ToString() ?? "NULL" : "")
                                                    </Template>
                                                </RadzenDataGridColumn>
                                            }
                                        </Columns>
                                    </RadzenDataGrid>
                                </div>
                            }
                        }
                    </div>
                </RadzenTabsItem>

                @* ── Credits ───────────────────────────────────────────────── *@
                <RadzenTabsItem Text="Credits" Icon="favorite">
                    <RadzenStack Orientation="Orientation.Vertical" Gap="2rem" Style="padding: 1.5rem; max-width: 900px;">

                        @* -- Section: Hard- and software -- *@
                        <RadzenText TextStyle="TextStyle.H5" Style="margin-bottom: 0.5rem;">
                            <RadzenIcon Icon="devices" Style="vertical-align: middle; margin-right: 6px;" />
                            Hard- and software
                        </RadzenText>
                        <RadzenRow Gap="1rem">

                            @* Charged *@
                            <RadzenColumn SizeSM="3">
                                <RadzenCard class="rz-background-color-primary" Style="height:100%; text-align:center; padding: 1.25rem;">
                                    <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary" Style="display:block; margin-bottom:0.75rem; opacity:0.7;">Hardware</RadzenText>
                                    <a href="https://charged.nu/" target="_blank" Style="display:block; margin-bottom:0.75rem;">
                                        <RadzenImage Path="/Images/Charged_transparent_final.png"
                                                     Style="width:90px; height:60px; object-fit:contain; background:transparent;" />
                                    </a>
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-on-primary"><b>Charged B.V.</b></RadzenText>
                                </RadzenCard>
                            </RadzenColumn>

                            @* Sessy *@
                            <RadzenColumn SizeSM="3">
                                <RadzenCard class="rz-background-color-primary" Style="height:100%; text-align:center; padding: 1.25rem;">
                                    <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary" Style="display:block; margin-bottom:0.75rem; opacity:0.7;">Battery communication</RadzenText>
                                    <a href="https://sessy.nl/" target="_blank" Style="display:block; margin-bottom:0.75rem;">
                                        <RadzenImage Path="/Images/sessy.svg"
                                                     Style="width:90px; height:60px; object-fit:contain; background:transparent;" />
                                    </a>
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-on-primary"><b>Sessy</b></RadzenText>
                                </RadzenCard>
                            </RadzenColumn>

                            @* Microsoft *@
                            <RadzenColumn SizeSM="3">
                                <RadzenCard class="rz-background-color-primary" Style="height:100%; text-align:center; padding: 1.25rem;">
                                    <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary" Style="display:block; margin-bottom:0.75rem; opacity:0.7;">.NET development</RadzenText>
                                    <a href="https://microsoft.com/" target="_blank" Style="display:block; margin-bottom:0.75rem;">
                                        <RadzenImage Path="/Images/Microsoft.jpg"
                                                     Style="width:90px; height:60px; object-fit:contain; background:transparent;" />
                                    </a>
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-on-primary"><b>Microsoft</b></RadzenText>
                                </RadzenCard>
                            </RadzenColumn>

                            @* Radzen *@
                            <RadzenColumn SizeSM="3">
                                <RadzenCard class="rz-background-color-primary" Style="height:100%; text-align:center; padding: 1.25rem;">
                                    <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary" Style="display:block; margin-bottom:0.75rem; opacity:0.7;">UI web components</RadzenText>
                                    <a href="https://radzen.com/" target="_blank" Style="display:block; margin-bottom:0.75rem;">
                                        <RadzenImage Path="/Images/Radzen_transparent_final.png"
                                                     Style="width:50px; height:60px; object-fit:contain; background:transparent;" />
                                    </a>
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-on-primary"><b>Radzen (free)</b></RadzenText>
                                </RadzenCard>
                            </RadzenColumn>

                            @* Google OR-Tools *@
                            <RadzenColumn SizeSM="3">
                                <RadzenCard class="rz-background-color-primary" Style="height:100%; text-align:center; padding: 1.25rem;">
                                    <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary" Style="display:block; margin-bottom:0.75rem; opacity:0.7;">MILP battery planning</RadzenText>
                                    <a href="https://developers.google.com/optimization" target="_blank" Style="display:block; margin-bottom:0.75rem;">
                                        <RadzenImage Path="/Images/google-or-tools.svg"
                                                     Style="width:120px; height:60px; object-fit:contain; background:transparent;" />
                                    </a>
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-on-primary"><b>Google OR-Tools</b></RadzenText>
                                </RadzenCard>
                            </RadzenColumn>

                        </RadzenRow>

                        @* -- Section: Online services -- *@
                        <RadzenText TextStyle="TextStyle.H5" Style="margin-bottom: 0.5rem; margin-top: 0.5rem;">
                            <RadzenIcon Icon="cloud" Style="vertical-align: middle; margin-right: 6px;" />
                            Online services
                        </RadzenText>
                        <RadzenRow Gap="1rem">

                            @* Weeronline *@
                            <RadzenColumn SizeSM="3">
                                <RadzenCard class="rz-background-color-primary" Style="height:100%; text-align:center; padding: 1.25rem;">
                                    <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary" Style="display:block; margin-bottom:0.75rem; opacity:0.7;">Weather service</RadzenText>
                                    <a href="https://weeronline.nl" target="_blank" Style="display:block; margin-bottom:0.75rem;">
                                        <RadzenImage Path="/Images/wol_logo_white.svg"
                                                     Style="width:90px; height:60px; object-fit:contain;" />
                                    </a>
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-on-primary"><b>Weeronline</b></RadzenText>
                                </RadzenCard>
                            </RadzenColumn>

                            @* Enever.nl *@
                            <RadzenColumn SizeSM="3">
                                <RadzenCard class="rz-background-color-primary" Style="height:100%; text-align:center; padding: 1.25rem;">
                                    <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary" Style="display:block; margin-bottom:0.75rem; opacity:0.7;">Gas price feed</RadzenText>
                                    <a href="https://enever.nl" target="_blank" Style="display:block; margin-bottom:0.75rem;">
                                        <RadzenImage Path="/Images/enever.svg"
                                                     Style="width:120px; height:60px; object-fit:contain; background:transparent;" />
                                    </a>
                                    <RadzenText TextStyle="TextStyle.Body2" class="rz-color-on-primary"><b>Enever.nl</b></RadzenText>
                                </RadzenCard>
                            </RadzenColumn>

                        </RadzenRow>
                    </RadzenStack>
                </RadzenTabsItem>

            </Tabs>
        </RadzenTabs>
    </RadzenBody>
</RadzenLayout>

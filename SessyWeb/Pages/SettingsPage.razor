@page "/settings"
@inherits PageBase
@using SessyData.Model
@using Radzen
@using Radzen.Blazor

<RadzenLayout Style="height: 80vh;">
    <RadzenHeader Style="height: 100%; margin: 0px; padding: 0px;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Style="height:100%; margin: 0px; padding: 0px;">
            <RadzenLabel Text="Settings" class="h4 m-2" />
        </RadzenStack>
    </RadzenHeader>

    <RadzenBody Style="margin: 8px; padding: 0px; overflow-y: auto;">
        <RadzenTabs RenderMode="TabRenderMode.Client">

            @* ── Investment Groups ─────────────────────────────────────────── *@
            <Tabs>
                <RadzenTabsItem Text="Investment Groups" Icon="category">
                    <RadzenDataGrid @ref="groupsGrid"
                                    Data="@GroupList"
                                    TItem="InvestmentGroup"
                                    Count="@groupCount"
                                    LoadData="@LoadGroupData"
                                    IsLoading="@isGroupLoading"
                                    RowUpdate="@OnUpdateGroup"
                                    RowCreate="@OnCreateGroup"
                                    Responsive="true"
                                    AllowSorting="true"
                                    AllowFiltering="true"
                                    AllowPaging="true"
                                    PageSize="20"
                                    Density="Density.Compact"
                                    PagerHorizontalAlign="HorizontalAlign.Left">
                        <HeaderTemplate>
                            <RadzenButton ButtonStyle="ButtonStyle.Success"
                                          Icon="add_circle"
                                          Text="Add group"
                                          Click="@InsertGroup" />
                        </HeaderTemplate>
                        <Columns>
                            <RadzenDataGridColumn Property="@nameof(InvestmentGroup.Name)" Title="Name">
                                <EditTemplate Context="grp">
                                    <RadzenTextBox @bind-Value="grp.Name" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(InvestmentGroup.Category)" Title="Category">
                                <EditTemplate Context="grp">
                                    <RadzenDropDown @bind-Value="grp.Category"
                                                    Data="@Categories"
                                                    Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(InvestmentGroup.Description)" Title="Description">
                                <EditTemplate Context="grp">
                                    <RadzenTextBox @bind-Value="grp.Description" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Context="grp" Filterable="false" Sortable="false"
                                                  TextAlign="TextAlign.Right" Frozen="true"
                                                  FrozenPosition="FrozenColumnPosition.Right">
                                <Template Context="grp">
                                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" class="rz-my-1"
                                                  Click="@(args => EditGroup(grp))" @onclick:stopPropagation="true" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => DeleteGroup(grp))" @onclick:stopPropagation="true" />
                                </Template>
                                <EditTemplate Context="grp">
                                    <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Click="@((args) => SaveGroup(grp))" aria-label="Save" />
                                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" class="rz-my-1 rz-ms-1"
                                                  Click="@((args) => CancelGroupEdit(grp))" aria-label="Cancel" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => DeleteGroup(grp))" aria-label="Delete" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>

                @* ── Investments ───────────────────────────────────────────── *@
                <RadzenTabsItem Text="Investments" Icon="payments">
                    <RadzenDataGrid @ref="investmentsGrid"
                                    Data="@InvestmentList"
                                    TItem="Investment"
                                    Count="@investmentCount"
                                    LoadData="@LoadInvestmentData"
                                    IsLoading="@isInvestmentLoading"
                                    RowUpdate="@OnUpdateInvestment"
                                    RowCreate="@OnCreateInvestment"
                                    Responsive="true"
                                    AllowSorting="true"
                                    AllowFiltering="true"
                                    AllowPaging="true"
                                    PageSize="20"
                                    Density="Density.Compact"
                                    PagerHorizontalAlign="HorizontalAlign.Left">
                        <HeaderTemplate>
                            <RadzenButton ButtonStyle="ButtonStyle.Success" Icon="add_circle"
                                          Text="Add investment" Click="@InsertInvestment" />
                            <RadzenText TextStyle="TextStyle.Body1" class="rz-ms-4">
                                Total: <strong>€ @InvestmentList?.Sum(i => i.AmountEur).ToString("F2")</strong> |
                                Subsidies: <strong>€ @InvestmentList?.Sum(i => i.SubsidyEur).ToString("F2")</strong> |
                                Net: <strong>€ @InvestmentList?.Sum(i => i.NetAmountEur).ToString("F2")</strong>
                            </RadzenText>
                        </HeaderTemplate>
                        <Columns>
                            <RadzenDataGridColumn Property="@nameof(Investment.InvestmentGroupId)" Title="Group">
                                <Template Context="inv">
                                    @(Groups.FirstOrDefault(g => g.Id == inv.InvestmentGroupId)?.Name ?? "—")
                                </Template>
                                <EditTemplate Context="inv">
                                    <RadzenDropDown @bind-Value="inv.InvestmentGroupId"
                                                    Data="@Groups"
                                                    TextProperty="Name"
                                                    ValueProperty="Id"
                                                    AllowClear="true"
                                                    Placeholder="— no group —"
                                                    Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.Description)" Title="Description">
                                <EditTemplate Context="inv">
                                    <RadzenTextBox @bind-Value="inv.Description" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.PurchaseDate)" Title="Purchase date"
                                                  SortOrder="SortOrder.Ascending" FormatString="{0:dd-MM-yyyy}">
                                <EditTemplate Context="inv">
                                    <RadzenDatePicker @bind-Value="inv.PurchaseDate" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.AmountEur)" Title="Amount (€)" FormatString="{0:F2}">
                                <EditTemplate Context="inv">
                                    <RadzenNumeric @bind-Value="inv.AmountEur" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.SubsidyEur)" Title="Subsidy (€)" FormatString="{0:F2}">
                                <EditTemplate Context="inv">
                                    <RadzenNumeric @bind-Value="inv.SubsidyEur" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.NetAmountEur)" Title="Net (€)" FormatString="{0:F2}">
                                <Template Context="inv">@inv.NetAmountEur.ToString("F2")</Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.ExpectedLifetimeYears)" Title="Lifetime (yr)">
                                <EditTemplate Context="inv">
                                    <RadzenNumeric @bind-Value="inv.ExpectedLifetimeYears" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.EstimatedAnnualSavingsEur)" Title="Est. savings (€/yr)" FormatString="{0:F2}">
                                <EditTemplate Context="inv">
                                    <RadzenNumeric @bind-Value="inv.EstimatedAnnualSavingsEur" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.SavingsDescription)" Title="Savings description">
                                <EditTemplate Context="inv">
                                    <RadzenTextBox @bind-Value="inv.SavingsDescription" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Investment.Notes)" Title="Notes">
                                <EditTemplate Context="inv">
                                    <RadzenTextBox @bind-Value="inv.Notes" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Context="inv" Filterable="false" Sortable="false"
                                                  TextAlign="TextAlign.Right" Frozen="true"
                                                  FrozenPosition="FrozenColumnPosition.Right">
                                <Template Context="inv">
                                    <RadzenButton Icon="add_circle" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter"
                                                  Click="@(() => InsertInvestmentAfterRow(inv))"
                                                  title="Add new row after this row" />
                                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => EditInvestment(inv))" @onclick:stopPropagation="true" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => DeleteInvestment(inv))" @onclick:stopPropagation="true" />
                                </Template>
                                <EditTemplate Context="inv">
                                    <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Click="@((args) => SaveInvestment(inv))" aria-label="Save" />
                                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" class="rz-my-1 rz-ms-1"
                                                  Click="@((args) => CancelInvestmentEdit(inv))" aria-label="Cancel" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => DeleteInvestment(inv))" aria-label="Delete" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>

                @* ── Taxes ─────────────────────────────────────────────────── *@
                <RadzenTabsItem Text="Taxes" Icon="receipt_long">
                    <RadzenDataGrid @ref="taxesGrid"
                                    Data="@TaxesList"
                                    TItem="Taxes"
                                    Count="@taxCount"
                                    LoadData="@LoadTaxData"
                                    IsLoading="@isTaxLoading"
                                    RowUpdate="@OnUpdateTax"
                                    RowCreate="@OnCreateTax"
                                    Responsive="true"
                                    AllowSorting="true"
                                    AllowFiltering="true"
                                    AllowPaging="true"
                                    PageSize="20"
                                    Density="Density.Compact"
                                    PagerHorizontalAlign="HorizontalAlign.Left">
                        <HeaderTemplate>
                            <RadzenButton ButtonStyle="ButtonStyle.Success" Icon="add_circle"
                                          Text="Add taxes" Click="@InsertTax" />
                        </HeaderTemplate>
                        <Columns>
                            <RadzenDataGridColumn Property="@nameof(Taxes.Time)" Title="Time" SortOrder="SortOrder.Ascending">
                                <EditTemplate Context="t">
                                    <RadzenDatePicker @bind-Value="t.Time" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.EnergyTax)" Title="Energy tax">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.EnergyTax" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.ValueAddedTax)" Title="Value added tax">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.ValueAddedTax" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.TaxReduction)" Title="Tax reduction">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.TaxReduction" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.PurchaseCompensation)" Title="Purchase compensation">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.PurchaseCompensation" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.ReturnDeliveryCompensation)" Title="Return delivery compensation">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.ReturnDeliveryCompensation" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.NetManagementCost)" Title="Net management cost">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.NetManagementCost" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.FixedTransportFee)" Title="Fixed transport fee">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.FixedTransportFee" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.CapacityTransportFee)" Title="Capacity transport fee">
                                <EditTemplate Context="t">
                                    <RadzenNumeric @bind-Value="t.CapacityTransportFee" Style="width:100%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Property="@nameof(Taxes.Netting)" Title="Netting">
                                <EditTemplate Context="t">
                                    <RadzenCheckBox @bind-Value="t.Netting" Style="width:10%" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn Context="t" Filterable="false" Sortable="false"
                                                  TextAlign="TextAlign.Right" Frozen="true"
                                                  FrozenPosition="FrozenColumnPosition.Right">
                                <Template Context="t">
                                    <RadzenButton Icon="add_circle" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter"
                                                  Click="@(() => InsertTaxAfterRow(t))"
                                                  title="Add new row after this row" />
                                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => EditTax(t))" @onclick:stopPropagation="true" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => DeleteTax(t))" @onclick:stopPropagation="true" />
                                </Template>
                                <EditTemplate Context="t">
                                    <RadzenButton Icon="check" ButtonStyle="ButtonStyle.Success" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Click="@((args) => SaveTax(t))" aria-label="Save" />
                                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" class="rz-my-1 rz-ms-1"
                                                  Click="@((args) => CancelTaxEdit(t))" aria-label="Cancel" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat"
                                                  Size="ButtonSize.Small" Shade="Shade.Lighter" class="rz-my-1 rz-ms-1"
                                                  Click="@(args => DeleteTax(t))" aria-label="Delete" />
                                </EditTemplate>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>

                @* ── Who's in control ──────────────────────────────────────── *@
                <RadzenTabsItem Text="Who's in control" Icon="tune">
                    <RadzenDataGrid @ref="controlGrid"
                                    Data="@ControlList"
                                    Context="data"
                                    Count="@controlCount"
                                    LoadData="@LoadControlData"
                                    Responsive="true"
                                    AllowSorting="true"
                                    AllowFiltering="true"
                                    AllowPaging="true"
                                    PageSize="20"
                                    Density="Density.Compact"
                                    PagerHorizontalAlign="HorizontalAlign.Center">
                        <Columns>
                            <RadzenDataGridColumn Property="@nameof(SessyWebControl.Time)" Title="Time" SortOrder="SortOrder.Ascending" />
                            <RadzenDataGridColumn Property="@nameof(SessyWebControl.Status)" Title="Status" />
                        </Columns>
                    </RadzenDataGrid>
                </RadzenTabsItem>

                @* ── Credits ───────────────────────────────────────────────── *@
                <RadzenTabsItem Text="Credits" Icon="favorite">
                    <RadzenCard title="Sessy battery" Style="background-color: transparent; width:100%;">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                            <RadzenStack Orientation="Orientation.Vertical" AlignItems="AlignItems.Normal" Style="width: 100%; max-width: 1000px;">
                                <RadzenCard class="rz-background-color-primary-light rz-shadow-0 rz-border-radius-0 rz-p-8 rz-border-radius-2"
                                            style="margin: 1rem calc(-1 * var(--rz-card-padding));">
                                    <RadzenRow RowGap="0" Gap="10">
                                        <RadzenColumn SizeSM="4">
                                            <RadzenText TextStyle="TextStyle.H4" class="rz-color-on-primary-light rz-display-flex rz-mt-4 rz-mb-0">Hard- and software</RadzenText>
                                            <a href="https://charged.nu/" target="_blank">
                                                <RadzenImage Path="/Images/Charged_transparent_final.png" Style="background-color: transparent; width: 100px;" />
                                            </a>
                                            <RadzenText TextStyle="TextStyle.Body1" class="rz-color-on-primary-light"><b>Charged B.V.</b></RadzenText>

                                            <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary-light rz-display-flex rz-mt-4 rz-mb-0">Battery communication</RadzenText>
                                            <a href="https://sessy.nl/" target="_blank">
                                                <RadzenImage Path="/Images/sessy.svg" Style="background-color: transparent;" />
                                            </a>
                                            <RadzenText TextStyle="TextStyle.Body1" class="rz-color-on-primary-light"><b>Sessy slimme onafhankelijke thuisbatterij</b></RadzenText>

                                            <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary-light rz-display-flex rz-mt-4 rz-mb-0">.NET Development environment</RadzenText>
                                            <a href="https://microsoft.com/" target="_blank">
                                                <RadzenImage Path="/Images/Microsoft.jpg" Style="background-color: transparent; width: 100px;" />
                                            </a>

                                            <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary-light rz-display-flex rz-mt-4 rz-mb-0">UI web components</RadzenText>
                                            <a href="https://radzen.com/" target="_blank">
                                                <RadzenImage Path="/Images/Radzen_transparent_final.png" Style="background-color: transparent; width: 50px;" />
                                            </a>
                                            <RadzenText TextStyle="TextStyle.Body1" class="rz-color-on-primary-light"><b>Radzen components (free version)</b></RadzenText>

                                            <RadzenText TextStyle="TextStyle.H4" class="rz-color-on-primary-light rz-display-flex rz-mt-4 rz-mb-0">Online services</RadzenText>

                                            <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary-light rz-display-flex rz-mt-4 rz-mb-0">Weather service</RadzenText>
                                            <a href="https://weeronline.nl" target="_blank">
                                                <RadzenImage Path="/Images/wol_logo_white.svg" />
                                            </a>

                                            <RadzenText TextStyle="TextStyle.Overline" class="rz-color-on-primary-light rz-display-flex rz-mt-4 rz-mb-0">MILP battery planning solver</RadzenText>
                                            <a href="https://developers.google.com/optimization" target="_blank">
                                                <RadzenImage Path="/Images/Google.png" Style="background-color: transparent; width: 100px;" />
                                            </a>
                                            <RadzenText TextStyle="TextStyle.Body1" class="rz-color-on-primary-light"><b>Google OR-Tools</b></RadzenText>
                                        </RadzenColumn>
                                    </RadzenRow>
                                </RadzenCard>
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenTabsItem>

            </Tabs>
        </RadzenTabs>
    </RadzenBody>
</RadzenLayout>

@using Microsoft.AspNetCore.Components.Web
@using Radzen.Blazor

@namespace SessyWeb.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
    <link href="css/site.css" rel="stylesheet" />
    <link href="SessyWeb.styles.css" rel="stylesheet" />
</head>
<body>
    @RenderBody()

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <!--
        Autostart disabled so we can configure reconnect behavior manually.
        Improves reliability on iPhone with OpenVPN: Safari suspends the WebSocket
        when the app goes to the background, causing slow or failed reconnects.
    -->
    <script src="_framework/blazor.server.js" autostart="false"></script>
    <script>
        Blazor.start({
        configureSignalR: function (builder) {
        // Match the server-side HubOptions values set in Program.cs
        builder.withKeepAliveInterval(15000);  // 15 seconds
        builder.withServerTimeout(60000);       // 60 seconds
        },
        reconnectionOptions: {
        // 12 retries gives ~60 seconds of attempts, enough for a VPN reconnect
        maxRetries: 12,
        retryIntervalMilliseconds: function (previousAttempts) {
        // Fast retries first, then slow down to avoid hammering the server
        // Attempt 0=0s, 1=1s, 2=2s, 3=3s, 4+=5s
        return previousAttempts < 4
        ? previousAttempts * 1000
        : 5000;
        }
        }
        }).then(function () {
        // Blazor.start() must complete before defaultReconnectionHandler is available
        Blazor.defaultReconnectionHandler.onReconnectionFailed = function () {
        // If all reconnect attempts fail, reload the page automatically.
        // Prevents the user from being stuck on a dead screen after a VPN drop.
        window.location.reload();
        };
        });
    </script>
</body>
</html>


<script src="_content/Radzen.Blazor/Radzen.Blazor.js?v=@(typeof(Radzen.Colors).Assembly.GetName().Version)"></script>
<persist-component-state /> <!-- Must be behind the list script tag -->

@page "/investmentgroups"
@inherits PageBase
@using SessyData.Model
@using Radzen

<a>Investment Groups</a>

<RadzenDataGrid @ref="groupsGrid"
                Data="@GroupList"
                TItem="InvestmentGroup"
                Count="@count"
                LoadData="@LoadData"
                IsLoading="@isLoading"
                RowUpdate="@OnUpdateRow"
                RowCreate="@OnCreateRow"
                Responsive="true"
                AllowSorting="true"
                AllowFiltering="true"
                AllowPaging="true"
                PageSize="20"
                Density="Density.Compact"
                PagerHorizontalAlign="HorizontalAlign.Left">
    <HeaderTemplate>
        <RadzenButton ButtonStyle="ButtonStyle.Success"
                      Icon="add_circle"
                      Text="Add group"
                      Click="@InsertRow" />
    </HeaderTemplate>
    <Columns>
        <RadzenDataGridColumn Property="@nameof(InvestmentGroup.Name)" Title="Name">
            <EditTemplate Context="grp">
                <RadzenTextBox @bind-Value="grp.Name" Style="width:100%" />
            </EditTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Property="@nameof(InvestmentGroup.Category)" Title="Category">
            <EditTemplate Context="grp">
                <RadzenDropDown @bind-Value="grp.Category"
                                Data="@Categories"
                                Style="width:100%" />
            </EditTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Property="@nameof(InvestmentGroup.Description)" Title="Description">
            <EditTemplate Context="grp">
                <RadzenTextBox @bind-Value="grp.Description" Style="width:100%" />
            </EditTemplate>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn Context="grp"
                              Filterable="false"
                              Sortable="false"
                              TextAlign="TextAlign.Right"
                              Frozen="true"
                              FrozenPosition="FrozenColumnPosition.Right">
            <Template Context="grp">
                <RadzenButton Icon="edit"
                              ButtonStyle="ButtonStyle.Light"
                              Variant="Variant.Flat"
                              Size="ButtonSize.Small"
                              class="rz-my-1"
                              Click="@(args => EditRow(grp))"
                              @onclick:stopPropagation="true" />
                <RadzenButton Icon="delete"
                              ButtonStyle="ButtonStyle.Danger"
                              Variant="Variant.Flat"
                              Size="ButtonSize.Small"
                              Shade="Shade.Lighter"
                              class="rz-my-1 rz-ms-1"
                              Click="@(args => DeleteRow(grp))"
                              @onclick:stopPropagation="true" />
            </Template>
            <EditTemplate Context="grp">
                <RadzenButton Icon="check"
                              ButtonStyle="ButtonStyle.Success"
                              Variant="Variant.Flat"
                              Size="ButtonSize.Small"
                              Click="@((args) => SaveRow(grp))"
                              aria-label="Save" />
                <RadzenButton Icon="close"
                              ButtonStyle="ButtonStyle.Light"
                              Variant="Variant.Flat"
                              Size="ButtonSize.Small"
                              class="rz-my-1 rz-ms-1"
                              Click="@((args) => CancelEdit(grp))"
                              aria-label="Cancel" />
                <RadzenButton Icon="delete"
                              ButtonStyle="ButtonStyle.Danger"
                              Variant="Variant.Flat"
                              Size="ButtonSize.Small"
                              Shade="Shade.Lighter"
                              class="rz-my-1 rz-ms-1"
                              Click="@(args => DeleteRow(grp))"
                              aria-label="Delete" />
            </EditTemplate>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

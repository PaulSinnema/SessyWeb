@page "/"
@page "/charginghours"
@inherits PageBase
@using System
@using Radzen
@using SessyController.Services.StateMachine
@using Radzen.Blazor
@using SessyWeb.Components
@using SessyController.Services.Items
@using static SessyWeb.Components.DateChooserComponent

@{
    var desktop = !ScreenInfo?.IsMobile ?? false;

    if (desktop)
    {
        <RadzenCard Style="padding: 3px 3px 5px 10px;">
            <RadzenTable>
                <RadzenTableRow>
                    <RadzenTableCell Style="width: 100px;vertical-align: top;">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="0" AlignItems="AlignItems.Start" Style="width: 200px;">
                            <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Date</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2"><b>@_timeZoneService!.Now.Date.AddDays(-1).ToString("dd-MM-yyyy")</b></RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"><b>@_timeZoneService!.Now.Date.ToString("dd-MM-yyyy")</b></RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2"><b>@_timeZoneService!.Now.AddDays(1).Date.ToString("dd-MM-yyyy")</b></RadzenText>
                        </RadzenStack>
                    </RadzenTableCell>

                    <RadzenTableCell Style="width: 75px;vertical-align: top;">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="0" AlignItems="AlignItems.Start" Style="width: 200px;">
                            <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Solar</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"><b>@(TotalSolarPowerYesterday > 0 ? $"⚡{TotalSolarPowerYesterdayVisual}" : "--")</b></RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"><b>⚡@TotalSolarPowerExpectedTodayVisual</b></RadzenText>
                            @if (TotalSolarPowerExpectedTomorrow > 0)
                            {
                                <RadzenText TextStyle="TextStyle.Body1"><b>⚡@TotalSolarPowerExpectedTomorrowVisual</b></RadzenText>
                            }
                        </RadzenStack>
                    </RadzenTableCell>

                    <RadzenTableCell Style="width: 75px;vertical-align: top;">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="0" AlignItems="AlignItems.Start" Style="width: 150px;">
                            <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Cost</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"><b>€ @TotalRevenueExpectedYesterdayVisual</b></RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"><b>€ @TotalRevenueExpectedTodayVisual</b></RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"><b>--</b></RadzenText>
                        </RadzenStack>
                    </RadzenTableCell>

                    <RadzenTableCell Style="width: 75px;vertical-align: top;">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="0" AlignItems="AlignItems.Start" Style="width: 175px;">
                            <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Inverter</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"><b>@currentThrottlePercentage %</b></RadzenText>
                            @{
                                var curtailmentMode = _stateMachine?.CurrentAction.CurtailmentMode ?? CurtailmentMode.None;
                                if (curtailmentMode != CurtailmentMode.None)
                                {
                                    <RadzenBadge BadgeStyle="@(curtailmentMode == CurtailmentMode.Shutdown ? BadgeStyle.Danger : BadgeStyle.Warning)"
                                                 Style="color: black; font-size: 0.7rem;"
                                                 Text="@(curtailmentMode switch
                                                 {
                                                     CurtailmentMode.Shutdown => "SHUTDOWN",
                                                     CurtailmentMode.ZeroExport => "ZERO EXPORT",
                                                     CurtailmentMode.Throttle => "THROTTLE",
                                                     _ => ""
                                                 })" />
                                }
                            }
                            <RadzenText TextStyle="TextStyle.Caption" Style="opacity: 0.6; margin-top: 2px;">
                                Actual: @($"{_hardwareStatusService?.ThrottlePct:F0} %")
                            </RadzenText>
                        </RadzenStack>
                    </RadzenTableCell>

                    <RadzenTableCell Style="width: 120px;vertical-align: top;">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="0" AlignItems="AlignItems.Start" Style="width: 150px;">
                            <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Battery (plan)</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"><b>@BatteryPercentageVisual</b></RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"><b>@BatteryMode</b></RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="opacity: 0.6; margin-top: 2px;">@OptimizationStrategyName</RadzenText>
                            <RadzenText TextStyle="TextStyle.Caption" Style="@($"opacity: 0.6; margin-top: 2px; color: {(SocDeviationPct > 10 ? "var(--rz-warning)" : "inherit")}")">
                                SOC dev: @($"{SocDeviationPct:F1}%")
                            </RadzenText>
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="2" AlignItems="AlignItems.Center">
                                @{
                                    if (BatteryWithStatusList != null)
                                    {
                                        foreach (var battery in BatteryWithStatusList!)
                                        {
                                            var style = $"background-color: {battery.StatusColor}; padding: 1px; cursor: pointer; width: 20px; text-align: center;";
                                            var title = $"{battery.StatusTitle}";
                                            <RadzenPanel style=@style title=@title>@battery.Battery.Id</RadzenPanel>
                                        }
                                    }
                                }
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenTableCell>

                    <RadzenTableCell Style="width: 120px;vertical-align: top;">
                        <RadzenStack Orientation="Orientation.Vertical" Gap="0" AlignItems="AlignItems.Start" Style="width: 150px;">
                            @{
                                var rawStrategy = _hardwareStatusService?.ActualBatteryStrategy ?? string.Empty;
                                var displayStrategy = rawStrategy switch
                                {
                                    "POWER_STRATEGY_API" => "Open API",
                                    "POWER_STRATEGY_NOM" => "Zero Net Home",
                                    "" => "—",
                                    _ => rawStrategy
                                };
                                var actualPowerW = _hardwareStatusService?.ActualBatteryPowerW ?? 0.0;
                                var powerLabel = actualPowerW < -50 ? "↑ charging"
                                              : actualPowerW > 50 ? "↓ discharging"
                                              : "idle";
                            }
                            <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Battery (actual)</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1"><b>@displayStrategy</b></RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2">@($"{actualPowerW:F0} W") @powerLabel</RadzenText>
                        </RadzenStack>
                    </RadzenTableCell>

                    <RadzenTableCell Style="width: 100%;vertical-align: top;">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="1" AlignItems="AlignItems.Start">
                            <RadzenStack Orientation="Orientation.Horizontal" Style="width: 100%;">
                                <RadzenStack Orientation="Orientation.Vertical" Gap="2" AlignItems="AlignItems.Start" Style="width: 150px;">
                                    <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Heartbeat</RadzenText>
                                    <div style="height: 20px; width: 20px; display: flex; align-items: center; justify-content: center;">
                                        @if (IsBeating)
                                        {
                                            <i class="fas fa-heart heartbeat" style="color: indianred; font-size: 24px;"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-heart" style="color: transparent; font-size: 24px;"></i>
                                        }
                                    </div>
                                </RadzenStack>

                                <RadzenStack Orientation="Orientation.Vertical" Gap="2" AlignItems="AlignItems.Start" Style="width: 150px;">
                                    <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Control</RadzenText>

                                    @if (IsManualOverride)
                                    {
                                        <i class="fas fa-hand hand" style="color: indianred; font-size: 24px;" title="Manual mode"></i>
                                    }

                                    @if (WeAreInControl)
                                    {
                                        <RadzenImage Path="/Images/sessy_web.png" Style="width: 40px;" title="SessyWeb in control" />
                                    }
                                    else
                                    {
                                        <i class="fas fa-industry" style="color: green; font-size: 24px;" title="Provider has control"></i>
                                    }
                                </RadzenStack>

                                <RadzenStack Orientation="Orientation.Vertical" Style="width: 100%;">
                                    <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Settings</RadzenText>

                                    <RadzenStack Orientation="Orientation.Horizontal" Gap="2" AlignItems="AlignItems.Start" Style="width: 100%;">
                                        <RadzenLabel Text="Show all" Component="ShowAll" Style="width: 100px;" />
                                        <RadzenCheckBox @bind-Value="ShowAll" Text="Show all data of today" Name="ShowAll" />
                                        @if (ShowAll)
                                        {
                                            <RadzenDropDown TValue="Guid?"
                                                            Data="@(_chartComponent?.AvailablePlans)"
                                                            TextProperty="@nameof(PlanHistoryOption.Label)"
                                                            ValueProperty="@nameof(PlanHistoryOption.PlanId)"
                                                            Value="@_chartComponent?.SelectedPlanId"
                                                            Change="@(async (object v) => await OnPlanSelected(v))"
                                                            Placeholder="Select a plan"
                                                            Style="width: 260px;" />
                                        }
                                    </RadzenStack>
                                </RadzenStack>

                                @if (desktop)
                                {
                                    <RadzenStack Orientation="Orientation.Vertical" Style="width: 100%;" Visible="@ShowAll">
                                        <RadzenStack Orientation="Orientation.Horizontal" Gap="2" AlignItems="AlignItems.Start" Style="width: 100%;">
                                            <DateChooserComponent SelectionChanged="@((DateArgs d) => SelectionChanged(d))" />
                                        </RadzenStack>
                                    </RadzenStack>
                                }
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenTableCell>
                </RadzenTableRow>
            </RadzenTable>
        </RadzenCard>

        @if (QuarterlyInfos != null && QuarterlyInfos.Count != 0)
        {
            <ChargingHoursChartComponent @ref="_chartComponent" QuarterlyInfos="@QuarterlyInfos" GraphStyle="@GraphStyle" ShowAll="@ShowAll" />
        }
    }
    else
    {
        @if (QuarterlyInfos != null && QuarterlyInfos.Count != 0)
        {
            <RadzenCard Style="padding: 3px 3px 5px 10px;">
                <RadzenStack Orientation="Orientation.Vertical" Gap="1" AlignItems="AlignItems.Start">

                    <RadzenText TextStyle="TextStyle.Overline" style="font-size: 0.9rem;" class="rz-display-flex rz-mt-4 rz-mb-0">Cost</RadzenText>

                    <RadzenTable>
                        <RadzenTableRow>
                            <RadzenTableCell Style="Width: 100px;">
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-display-flex rz-mt-4 rz-mb-0"><b>@_timeZoneService!.Now.Date.AddDays(-1).ToString("dd-MM-yyyy")</b></RadzenText>
                            </RadzenTableCell>
                            <RadzenTableCell>
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-display-flex rz-mt-4 rz-mb-0"><b>€ @TotalRevenueExpectedYesterdayVisual</b></RadzenText>
                            </RadzenTableCell>
                        </RadzenTableRow>
                        <RadzenTableRow>
                            <RadzenTableCell>
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-display-flex rz-mt-4 rz-mb-0"><b>@_timeZoneService!.Now.Date.ToString("dd-MM-yyyy")</b></RadzenText>
                            </RadzenTableCell>
                            <RadzenTableCell>
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-display-flex rz-mt-4 rz-mb-0"><b>€ @TotalRevenueExpectedTodayVisual</b></RadzenText>
                            </RadzenTableCell>
                        </RadzenTableRow>
                    </RadzenTable>

                    <RadzenText TextStyle="TextStyle.Overline" style="font-size: 0.9rem;" class="rz-display-flex rz-mt-4 rz-mb-0">Solar</RadzenText>

                    <RadzenTable>
                        <RadzenTableRow>
                            <RadzenTableCell Style="Width: 100px;">
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-display-flex rz-mt-4 rz-mb-0"><b>@_timeZoneService!.Now.Date.ToString("dd-MM-yyyy")</b></RadzenText>
                            </RadzenTableCell>
                            <RadzenTableCell>
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-display-flex rz-mt-4 rz-mb-0"><b>⚡@TotalSolarPowerExpectedTodayVisual</b></RadzenText>
                            </RadzenTableCell>
                        </RadzenTableRow>
                        <RadzenTableRow>
                            <RadzenTableCell Style="Width: 100px;">
                                <RadzenText TextStyle="TextStyle.Body2" class="rz-display-flex rz-mt-4 rz-mb-0"><b>@_timeZoneService!.Now.AddDays(1).Date.ToString("dd-MM-yyyy")</b></RadzenText>
                            </RadzenTableCell>
                            <RadzenTableCell>
                                @if (TotalSolarPowerExpectedTomorrow > 0)
                                {
                                    <RadzenText TextStyle="TextStyle.Body1" class="rz-display-flex rz-mt-4 rz-mb-0"><b>⚡@TotalSolarPowerExpectedTomorrowVisual</b></RadzenText>
                                }
                            </RadzenTableCell>
                        </RadzenTableRow>
                    </RadzenTable>

                    <RadzenText TextStyle="TextStyle.Overline" style="font-size: 0.9rem;" class="rz-display-flex rz-mt-4 rz-mb-0">Batteries</RadzenText>

                    <RadzenTable>
                        <RadzenTableRow>
                            <RadzenTableCell Style="Width: 100px;">
                                <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Storage</RadzenText>
                            </RadzenTableCell>
                            <RadzenTableCell>
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-display-flex rz-mt-4 rz-mb-0"><b>@BatteryPercentageVisual</b></RadzenText>
                            </RadzenTableCell>
                        </RadzenTableRow>

                        <RadzenTableRow>
                            <RadzenTableCell Style="Width: 100px;">
                                <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Statuses</RadzenText>
                            </RadzenTableCell>
                            <RadzenTableCell Style="Width: 100px;">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="2" AlignItems="AlignItems.Center">
                                    @{
                                        if (BatteryWithStatusList != null)
                                        {
                                            foreach (var battery in BatteryWithStatusList!)
                                            {
                                                var style = $"background-color: {battery.StatusColor}; padding: 1px; cursor: pointer; width: 20px; text-align: center;";
                                                var title = $"{battery.StatusTitle}";

                                                <RadzenPanel style=@style title=@title>@battery.Battery.Id</RadzenPanel>
                                            }
                                        }
                                    }
                                </RadzenStack>
                            </RadzenTableCell>
                        </RadzenTableRow>

                        <RadzenTableRow Visible="@WeAreInControl">
                            <RadzenTableCell Style="Width: 100px;">
                                <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Mode</RadzenText>
                            </RadzenTableCell>
                            <RadzenTableCell>
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-display-flex rz-mt-4 rz-mb-0"><b>@BatteryMode</b></RadzenText>
                            </RadzenTableCell>
                        </RadzenTableRow>

                        <RadzenTableRow>
                            <RadzenTableCell Style="Width: 100px;">
                                <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Heartbeat</RadzenText>
                            </RadzenTableCell>
                            <RadzenTableCell>
                                <div style="height: 20px; width: 20px; display: flex; align-items: center; justify-content: center; margin-left: 10px;">
                                    @if (IsBeating)
                                    {
                                        <i class="fas fa-heart heartbeat" style="color: indianred; font-size: 24px;"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-heart" style="color: transparent; font-size: 24px;"></i>
                                    }
                                </div>
                            </RadzenTableCell>
                        </RadzenTableRow>
                    </RadzenTable>

                    <RadzenText Visible="@WeAreInControl" TextStyle="TextStyle.Overline" style="font-size: 0.9rem;" class="rz-display-flex rz-mt-4 rz-mb-0">Next planned action</RadzenText>

                    <RadzenTable Visible="@WeAreInControl">
                        <RadzenTableRow>
                            <RadzenTableCell Style="Width: 100px;">
                                <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Time</RadzenText>
                            </RadzenTableCell>
                            <RadzenTableCell>
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-display-flex rz-mt-4 rz-mb-0"><b>@NextQuarterlyInfoInSession?.Time</b></RadzenText>
                            </RadzenTableCell>
                        </RadzenTableRow>
                        <RadzenTableRow>
                            <RadzenTableCell>
                                <RadzenText TextStyle="TextStyle.Overline" class="rz-display-flex rz-mt-4 rz-mb-0">Mode</RadzenText>
                            </RadzenTableCell>
                            <RadzenTableCell>
                                <RadzenText TextStyle="TextStyle.Body1" class="rz-display-flex rz-mt-4 rz-mb-0"><b>@NextQuarterlyInfoInSession?.GetDisplayMode()</b></RadzenText>
                            </RadzenTableCell>
                        </RadzenTableRow>
                    </RadzenTable>

                </RadzenStack>
            </RadzenCard>
        }
    }
}

@* Info button — sticky at bottom-left, always visible *@
<div style="position: sticky; bottom: calc(16px + env(safe-area-inset-bottom)); left: calc(16px + env(safe-area-inset-left));
    width: fit-content; z-index: 1000; margin-top: 8px; transform: translateZ(0);">
    <RadzenButton Click="@(() => _showHelp = !_showHelp)"
                  Style="border-radius: 50%; width: 29px; height: 29px; background: #f0c040; box-shadow: 0 2px 8px rgba(0,0,0,0.5); padding: 0;">
        <i class="fas fa-info" style="color: #1a1a2e; font-size: 12px;"></i>
    </RadzenButton>
</div>

@if (_showHelp)
{
    <div style="position: fixed; inset: 0; z-index: 2000; overflow-y: auto;
        background: rgba(0,0,0,0.6);
        padding: calc(16px + env(safe-area-inset-top)) calc(16px + env(safe-area-inset-right)) calc(16px + env(safe-area-inset-bottom)) calc(16px + env(safe-area-inset-left));"
         @onclick="@(() => _showHelp = false)">
        <div style="position: relative; margin: auto; width: 100%; max-width: 820px; box-sizing: border-box;"
             @onclick:stopPropagation="true">
            <button @onclick="@(() => _showHelp = false)"
                    style="position: absolute; top: 12px; left: 12px; z-index: 10;
                width: 36px; height: 36px; border-radius: 50%;
                background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.4);
                color: white; font-size: 18px; cursor: pointer;
                display: flex; align-items: center; justify-content: center;">
                ✕
            </button>
            <ChartHelpComponent />
        </div>
    </div>
}

@code {
    bool _showHelp = false;

    void ShowTooltipWithHtml(ElementReference elementReference, TooltipOptions? options = null)
        => tooltipService!.Open(elementReference, ds =>
@<ChartHelpComponent />, options);
}

@page "/energyStatistics"
@inherits PageBase
@using SessyController.Services.Statistics
@using SessyWeb.Components
@using Radzen
@using Radzen.Blazor

<RadzenLayout Style="height: 80vh;">
    <RadzenHeader Style="height: 100%; margin: 0px; padding: 0px;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Style="height:100%; margin: 0px; padding: 0px;">
            <RadzenLabel Text="Energy Statistics" class="h4 m-2" />
        </RadzenStack>
    </RadzenHeader>

    <RadzenBody Style="margin: 8px; padding: 0px; overflow-y: auto;">
        @if (IsLoading)
        {
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        }
        else if (Stats != null)
        {
            <RadzenRow Gap="8px">

                @* ── Energy flows ──────────────────────────────────────────── *@
                <RadzenColumn Size="12">
                    <RadzenCard>
                        <RadzenText TextStyle="TextStyle.H6">⚡ Energy Flows</RadzenText>
                        <RadzenRow>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Total consumption"    Value="@($"{Stats.TotalConsumptionKWh:F1} kWh")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Grid import"          Value="@($"{Stats.TotalGridImportKWh:F1} kWh")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Grid export"          Value="@($"{Stats.TotalGridExportKWh:F1} kWh")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Grid dependency"      Value="@($"{Stats.GridDependencyPct:F1} %")" />
                            </RadzenColumn>
                        </RadzenRow>
                    </RadzenCard>
                </RadzenColumn>

                @* ── Solar ────────────────────────────────────────────────── *@
                <RadzenColumn Size="12">
                    <RadzenCard>
                        <RadzenText TextStyle="TextStyle.H6">☀️ Solar</RadzenText>
                        <RadzenRow>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Total production"     Value="@($"{Stats.TotalSolarProductionKWh:F1} kWh")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Self consumed"        Value="@($"{Stats.SelfConsumedSolarKWh:F1} kWh")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Self consumption"     Value="@($"{Stats.SelfConsumptionPct:F1} %")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Self sufficiency"     Value="@($"{Stats.SelfSufficiencyPct:F1} %")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Avg daily production" Value="@($"{Stats.AvgDailySolarProductionKWh:F1} kWh/day")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Peak daily production" Value="@($"{Stats.PeakDailySolarProductionKWh:F1} kWh")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Performance ratio"   Value="@($"{Stats.SolarPerformanceRatio:P1}")" />
                            </RadzenColumn>
                        </RadzenRow>
                    </RadzenCard>
                </RadzenColumn>

                @* ── Battery ──────────────────────────────────────────────── *@
                <RadzenColumn Size="12">
                    <RadzenCard>
                        <RadzenText TextStyle="TextStyle.H6">🔋 Battery</RadzenText>
                        <RadzenRow>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Total charged"        Value="@($"{Stats.TotalBatteryChargedKWh:F1} kWh")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Total discharged"     Value="@($"{Stats.TotalBatteryDischargedKWh:F1} kWh")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Battery cycles"       Value="@($"{Stats.BatteryCycles:F1}")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Cycles per day"       Value="@($"{Stats.BatteryCyclesPerDay:F2}")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Round-trip efficiency" Value="@(Stats.BatteryRoundTripEfficiencyPct > 0 ? $"{Stats.BatteryRoundTripEfficiencyPct:F1} %" : "n/b")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Average SOC"          Value="@($"{Stats.AverageSocPct:F1} %")" />
                            </RadzenColumn>
                        </RadzenRow>
                    </RadzenCard>
                </RadzenColumn>

                @* ── Financial ────────────────────────────────────────────── *@
                <RadzenColumn Size="12">
                    <RadzenCard>
                        <RadzenText TextStyle="TextStyle.H6">💶 Financial</RadzenText>
                        <RadzenRow>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Actual energy cost"   Value="@($"€ {Stats.ActualEnergyCostEur:F2}")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Baseline cost"        Value="@($"€ {Stats.BaselineEnergyCostEur:F2}")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Total savings"        Value="@($"€ {Stats.TotalSavingsEur:F2}")" Highlight="true" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Grid export revenue"  Value="@($"€ {Stats.GridExportRevenueEur:F2}")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Arbitrage profit"     Value="@($"€ {Stats.ArbitrageProfitEur:F2}")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Avg buy price"        Value="@($"€ {Stats.WeightedAvgBuyPriceEurPerKWh:F4}/kWh")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Avg sell price"       Value="@($"€ {Stats.WeightedAvgSellPriceEurPerKWh:F4}/kWh")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Monthly savings"      Value="@($"€ {Stats.MonthlySavingsEur:F2}/month")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Annual savings"       Value="@($"€ {Stats.AnnualSavingsEur:F2}/year")" />
                            </RadzenColumn>
                        </RadzenRow>
                    </RadzenCard>
                </RadzenColumn>

                @* ── Consumption ──────────────────────────────────────────── *@
                <RadzenColumn Size="12">
                    <RadzenCard>
                        <RadzenText TextStyle="TextStyle.H6">🏠 Consumption</RadzenText>
                        <RadzenRow>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Avg daily consumption" Value="@($"{Stats.AvgDailyConsumptionKWh:F1} kWh/day")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Peak daily consumption" Value="@($"{Stats.PeakDailyConsumptionKWh:F1} kWh")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Weekday consumption"  Value="@($"{Stats.WeekdayConsumptionKWh:F1} kWh")" />
                            </RadzenColumn>
                            <RadzenColumn Size="6" SizeMD="3">
                                <StatCardComponent Title="Weekend consumption"  Value="@($"{Stats.WeekendConsumptionKWh:F1} kWh")" />
                            </RadzenColumn>
                        </RadzenRow>
                    </RadzenCard>
                </RadzenColumn>

                @* ── Investment ROI ───────────────────────────────────────── *@
                @if (InvestmentStats != null)
                {
                    <RadzenColumn Size="12">
                        <RadzenCard>
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
                                <RadzenText TextStyle="TextStyle.H6">📈 Return on Investment</RadzenText>
                                @if (InvestmentStats.UsesProjection)
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Warning"
                                                 Text="@($"Projection from {InvestmentStats.DataAvailableFrom:dd-MM-yyyy}")"
                                                 title="Insufficient historical data — savings before this date are extrapolated using seasonal monthly averages." />
                                }
                            </RadzenStack>
                            <RadzenRow>
                                <RadzenColumn Size="6" SizeMD="3">
                                    <StatCardComponent Title="Total investment"         Value="@($"€ {InvestmentStats.TotalNetInvestmentEur:F2}")" />
                                </RadzenColumn>
                                <RadzenColumn Size="6" SizeMD="3">
                                    <StatCardComponent Title="Realized savings"         Value="@($"€ {InvestmentStats.TotalRealizedSavingsEur:F2}")" />
                                </RadzenColumn>
                                @if (InvestmentStats.UsesProjection)
                                {
                                    <RadzenColumn Size="6" SizeMD="3">
                                        <StatCardComponent Title="Projected total savings"  Value="@($"€ {InvestmentStats.ProjectedTotalSavingsEur:F2}")" Highlight="true" />
                                    </RadzenColumn>
                                }
                                <RadzenColumn Size="6" SizeMD="3">
                                    <StatCardComponent Title="Remaining to recover"     Value="@($"€ {InvestmentStats.RemainingInvestmentEur:F2}")" />
                                </RadzenColumn>
                                <RadzenColumn Size="6" SizeMD="3">
                                    <StatCardComponent Title="Recovered"                Value="@($"{InvestmentStats.RecoveredPct:F1} %")" Highlight="true" />
                                </RadzenColumn>
                                <RadzenColumn Size="6" SizeMD="3">
                                    <StatCardComponent Title="Projected annual savings" Value="@($"€ {InvestmentStats.ProjectedAnnualSavingsEur:F2}/year")" />
                                </RadzenColumn>
                                <RadzenColumn Size="6" SizeMD="3">
                                    <StatCardComponent Title="Payback period" Value="@(InvestmentStats.ProjectedPaybackYears >= 999 ? "—" : $"{InvestmentStats.ProjectedPaybackYears:F1} years")" />
                                </RadzenColumn>
                                <RadzenColumn Size="6" SizeMD="3">
                                    <StatCardComponent Title="Break-even date"          Value="@(InvestmentStats.ProjectedBreakEvenDate.HasValue ? InvestmentStats.ProjectedBreakEvenDate.Value.ToString("dd-MM-yyyy") : "Unknown")" Highlight="true" />
                                </RadzenColumn>
                            </RadzenRow>

                            @* Category breakdown *@
                            @if (InvestmentStats.CategoryBreakdown.Any())
                            {
                                <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mt-4">Per component</RadzenText>
                                <RadzenDataGrid Data="@InvestmentStats.CategoryBreakdown"
                                                TItem="InvestmentCategoryStats"
                                                Density="Density.Compact"
                                                AllowSorting="false"
                                                AllowFiltering="false"
                                                AllowPaging="false">
                                    <Columns>
                                        <RadzenDataGridColumn Property="@nameof(InvestmentCategoryStats.Category)"                 Title="Component" />
                                        <RadzenDataGridColumn Property="@nameof(InvestmentCategoryStats.InstallationDate)"         Title="Since"            FormatString="{0:dd-MM-yyyy}" />
                                        <RadzenDataGridColumn Property="@nameof(InvestmentCategoryStats.NetAmountEur)"             Title="Net (€)"          FormatString="{0:F2}" />
                                        <RadzenDataGridColumn Property="@nameof(InvestmentCategoryStats.AnnualSavingsEur)"         Title="Savings (€/yr)"   FormatString="{0:F2}" />
                                        <RadzenDataGridColumn Property="@nameof(InvestmentCategoryStats.ProjectedTotalSavingsEur)" Title="Total saved (€)"  FormatString="{0:F2}" />
                                        <RadzenDataGridColumn Property="@nameof(InvestmentCategoryStats.RecoveredPct)"             Title="Recovered (%)"    FormatString="{0:F1}" />
                                        <RadzenDataGridColumn TItem="InvestmentCategoryStats" Title="Payback (yr)">
                                            <Template Context="cat">
                                                @(cat.PaybackYears >= 999 ? "—" : $"{cat.PaybackYears:F1}")
                                            </Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn TItem="InvestmentCategoryStats" Title="Break-even">
                                            <Template Context="cat">
                                                @(cat.BreakEvenDate.HasValue ? cat.BreakEvenDate.Value.ToString("dd-MM-yyyy") : "—")
                                            </Template>
                                        </RadzenDataGridColumn>
                                        <RadzenDataGridColumn Property="@nameof(InvestmentCategoryStats.SavingsSource)"            Title="Savings basis" />
                                    </Columns>
                                </RadzenDataGrid>
                            }
                        </RadzenCard>
                    </RadzenColumn>
                }

                @* ── Monthly trends chart ─────────────────────────────────── *@
                @if (MonthlyTrends != null && MonthlyTrends.Any())
                {
                    <RadzenColumn Size="12">
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.H6">📅 Monthly Trends</RadzenText>
                            <RadzenChart>
                                <RadzenColumnSeries Data="@MonthlyTrends"
                                                    CategoryProperty="@nameof(MonthlyTrend.PeriodStart)"
                                                    ValueProperty="@nameof(MonthlyTrend.SolarProductionKWh)"
                                                    Title="Solar (kWh)"
                                                    Fill="#f59e0b" />
                                <RadzenColumnSeries Data="@MonthlyTrends"
                                                    CategoryProperty="@nameof(MonthlyTrend.PeriodStart)"
                                                    ValueProperty="@nameof(MonthlyTrend.ConsumptionKWh)"
                                                    Title="Consumption (kWh)"
                                                    Fill="#3b82f6" />
                                <RadzenColumnSeries Data="@MonthlyTrends"
                                                    CategoryProperty="@nameof(MonthlyTrend.PeriodStart)"
                                                    ValueProperty="@nameof(MonthlyTrend.GridImportKWh)"
                                                    Title="Grid import (kWh)"
                                                    Fill="#ef4444" />
                                <RadzenLineSeries Data="@MonthlyTrends"
                                                  CategoryProperty="@nameof(MonthlyTrend.PeriodStart)"
                                                  ValueProperty="@nameof(MonthlyTrend.SavingsEur)"
                                                  Title="Savings (€)"
                                                  Stroke="#22c55e"
                                                  StrokeWidth="2" />
                                <RadzenCategoryAxis FormatString="{0:MMM yy}" />
                                <RadzenValueAxis>
                                    <RadzenGridLines Visible="true" />
                                </RadzenValueAxis>
                                <RadzenLegend Position="LegendPosition.Bottom" />
                            </RadzenChart>
                        </RadzenCard>
                    </RadzenColumn>
                }

            </RadzenRow>
        }
    </RadzenBody>
</RadzenLayout>

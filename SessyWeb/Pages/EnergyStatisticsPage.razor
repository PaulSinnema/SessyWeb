@page "/energyStatistics"
@inherits PageBase
@using SessyController.Services.Statistics
@using SessyWeb.Components
@using Radzen
@using Radzen.Blazor

<RadzenLayout Style="height: 80vh;">
    <RadzenHeader Style="height: 100%; margin: 0px; padding: 0px;">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Style="height:100%; margin: 0px; padding: 0px;">
            <RadzenLabel Text="Energy Statistics" class="h4 m-2" />
        </RadzenStack>
    </RadzenHeader>

    <RadzenBody Style="margin: 8px; padding: 0px; overflow-y: auto;">
        @if (IsLoading)
        {
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        }
        else if (Dashboard != null)
        {
            <RadzenRow Gap="8px">

                <RadzenColumn Size="12">
                    <ReturnOnInvestmentComponent Dashboard="@Dashboard" />
                </RadzenColumn>

                @if (Dashboard.HeatPumpIsConfigured)
                {
                    <RadzenColumn Size="12">
                        <HeatPumpSavingsComponent Dashboard="@Dashboard" />
                    </RadzenColumn>
                }

                <RadzenColumn Size="12">
                    <EnergySystemSavingsComponent Dashboard="@Dashboard" />
                </RadzenColumn>

                @if (Dashboard.Plan != null)
                {
                    <RadzenColumn Size="12">
                        <CurrentPlanComponent Dashboard="@Dashboard" OnClearPlanAsync="@ClearPlanAsync" />
                    </RadzenColumn>
                }

                <RadzenColumn Size="12" SizeMD="6">
                    <EnergyFlowsComponent Dashboard="@Dashboard" />
                </RadzenColumn>

                @if (Dashboard.DailyArbitrageTrends.Any())
                {
                    <RadzenColumn Size="12" SizeMD="6">
                        <DailyArbitrageChartComponent Dashboard="@Dashboard" />
                    </RadzenColumn>
                }

                <RadzenColumn Size="12" SizeMD="6">
                    <PlanVsActualComponent Dashboard="@Dashboard" />
                </RadzenColumn>

            </RadzenRow>
        }
    </RadzenBody>
</RadzenLayout>
